{
  "test_samples": [
    {
      "id": "sample_hindi_to_english",
      "description": "Standard Hindi to English translation",
      "source_language": "hi",
      "target_language": "en",
      "source_text": "आर्टिफिशियल इंटेलिजेंस के क्षेत्र में भारत की तरक्की कमाल की है, जो हेल्थकेयर, लैंग्वेज टेक्नोलॉजी और गवर्नेंस जैसे क्षेत्रों में इनोवेशन को बड़े पैमाने पर असल दुनिया के असर के साथ मिलाती है। देश का बढ़ता AI इकोसिस्टम रिसर्च, एथिकल डेवलपमेंट और सभी को शामिल करने वाले डिजिटल ट्रांसफॉर्मेशन के प्रति मज़बूत कमिटमेंट को दिखाता है।"
    },
    {
      "id": "sample_short_text",
      "description": "Short text translation",
      "source_language": "hi",
      "target_language": "en",
      "source_text": "नमस्ते, आप कैसे हैं?"
    },
    {
      "id": "sample_with_numbers",
      "description": "Text with numbers and special characters",
      "source_language": "hi",
      "target_language": "en",
      "source_text": "भारत में 2024 में AI का बजट ₹10,000 करोड़ है।"
    }
